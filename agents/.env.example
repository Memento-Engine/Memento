# ============================================================
# Agent Server Configuration
# ============================================================

# Server settings
SERVER_PORT=4173
SERVER_HOST=127.0.0.1
NODE_ENV=development

# ============================================================
# Language Model (LLM) Configuration
# ============================================================

# OpenRouter API key (required)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# LLM provider and model
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat
LLM_BASE_URL=https://openrouter.ai/api/v1

# LLM execution settings
LLM_TEMPERATURE=0
LLM_TIMEOUT=30000

# ============================================================
# Backend Service Configuration
# ============================================================

# Search tool backend URL
SEARCH_TOOL_URL=http://localhost:9090/api/v1/search_tool
BACKEND_TIMEOUT=30000

# ============================================================
# Logging Configuration
# ============================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: pretty (human-readable) or json (machine-readable)
LOG_FORMAT=pretty

# Latency logs (pino-based, no OpenTelemetry)
# Enable/disable latency instrumentation logs
LATENCY_LOGS=true
# Slow threshold in ms (marked as SLOW in latency.log)
LATENCY_SLOW_MS=1200
# Dedicated latency log file (tail this from another terminal)
LATENCY_LOG_FILE=logs/latency.log
# Also print latency logs into main app stream (false = keep streams separate)
LATENCY_TO_MAIN_LOG=false

# ============================================================
# Agent Execution Configuration
# ============================================================

# Maximum number of times to retry planning
MAX_PLAN_RETRIES=3

# Maximum number of times to retry individual execution steps
MAX_STEP_RETRIES=2

# Timeout for individual step execution (milliseconds)
STEP_TIMEOUT_MS=60000
