{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2022"],

    "outDir": "./dist-agents",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "allowSyntheticDefaultImports": true,

    "forceConsistentCasingInFileNames": true,

    "types": ["node"],

    "baseUrl": "./src",
    "paths": {
      "@agents/*": ["./*"],
      "@tools/*": ["./tools/*"],
      "@planner/*": ["./planner/*"],
      "@executor/*": ["./executor/*"]
    }
  },
  "include": [
    "./src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist-agents"]
}