{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:services": "concurrently -k -n frontend,agents -c cyan,magenta \"npm run dev --prefix frontend\" \"npm run dev --prefix agents\"",
    "build": "tsc && vite build",
    "build:all": "npm run build:agents && npm run build:frontend",
    "build:agents": "npm run build:exe --prefix agents",
    "build:frontend": "npm run build --prefix frontend",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run tauri dev"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.2.1",
    "tauri-plugin-keyring-api": "^0.1.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
