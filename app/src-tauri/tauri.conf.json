{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memento AI",
  "version": "0.1.0",
  "identifier": "com.mementoai.app",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:services",
    "beforeBuildCommand": "npm run build:all",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "Memento AI",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "C:/ProgramData/memento/data/memories/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["../agents/dist/memento-agents"],
    "icon": ["icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "keychain": null
  }
}
