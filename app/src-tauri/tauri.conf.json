{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memento AI",
  "version": "0.1.0",
  "identifier": "com.pavan.memento-ai",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd frontend &&  npm run dev",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "Memento AI",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.memento/memories/**",
          "C:/Users/pavan/Pictures/Screenshots/**",
          "C:/Users/*/.memento/memories/**",
          "C:/Users/pavan/.memento/memories/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "keychain": null
  }
}
