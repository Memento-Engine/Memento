{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "os:default",
    "os:allow-hostname",
    
    "keyring:default",
    "keyring:allow-set-password",
    "keyring:allow-get-password",
    "keyring:allow-delete-password",

    "fs:allow-localdata-read-recursive",
    "fs:allow-localdata-write-recursive"
  ]
}