# AI Gateway server
AI_GATEWAY_HOST=127.0.0.1
AI_GATEWAY_PORT=4180

# Provider credentials (minimum required to start)
# Either of these API key vars works for OpenRouter:
OPENROUTER_API_KEY=
# AI_GATEWAY_OPENROUTER_API_KEY=

# Optional OpenRouter endpoint override
AI_GATEWAY_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional model defaults
AI_GATEWAY_DEFAULT_MODEL=openai/gpt-4o-mini
AI_GATEWAY_DEFAULT_TEMPERATURE=0

# Optional role-based model policies
AI_GATEWAY_PLANNER_MODEL=openai/gpt-4o-mini
AI_GATEWAY_PLANNER_FALLBACKS=anthropic/claude-3-haiku
AI_GATEWAY_EXECUTOR_MODEL=deepseek/deepseek-chat
AI_GATEWAY_EXECUTOR_FALLBACKS=mistralai/mistral-large,openai/gpt-4o-mini
AI_GATEWAY_FINAL_MODEL=openai/gpt-4o-mini
AI_GATEWAY_FINAL_FALLBACKS=anthropic/claude-3-haiku

# Optional limits
AI_GATEWAY_FREE_RPM=20
AI_GATEWAY_FREE_DAILY_TOKENS=40000
AI_GATEWAY_PRO_RPM=120
AI_GATEWAY_PRO_DAILY_TOKENS=300000
AI_GATEWAY_PRO_USERS=

# JWT configuration (required for authentication)
JWT_ACCESS_SECRET=your-jwt-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=your-jwt-refresh-secret-at-least-32-characters

# Google OAuth configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
